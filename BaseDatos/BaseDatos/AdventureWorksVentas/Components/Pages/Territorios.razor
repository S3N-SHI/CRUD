@page "/territorios"
@page "/territorios/{id:int}"
@rendermode InteractiveServer

@using AdventureWorksVentas.DTOs

@inject AdventureWorksVentas.Services.TerritorioService TerritorioService

<PageTitle>Territorios</PageTitle>

<h3>Catálogo de Territorios</h3>

<div class="card shadow mt-3">

    <div class="card-header bg-primary text-white">
        Territorios - Catálogo (Maestro)
    </div>

    <div class="card-body">
<div class="row">

    <div class="col-md-6 mb-3">
        <label>🔒 Código <small class="text-muted">(autogenerado)</small></label>
        <input class="form-control"
               @bind="territorio.TerritoryID"
               readonly />
    </div>

    <div class="col-md-6 mb-3">
        <label>Nombre</label>
        <input class="form-control"
               @bind="territorio.NombreTerritorio" />
    </div>

    <div class="col-md-6 mb-3">
        <label>Código País</label>
        <input class="form-control"
               @bind="territorio.CountryRegionCode"
               maxlength="3" />
    </div>

    <div class="col-md-6 mb-3">
        <label>Grupo</label>
        <input class="form-control"
               @bind="territorio.Grupo" />
    </div>

</div>

<hr />

<button class="btn btn-success me-2"
        @onclick="NuevoTerritorio">
    Nuevo
</button>

<button class="btn btn-primary me-2"
        @onclick="Guardar">
    Guardar
</button>

<button class="btn btn-danger me-2"
        @onclick="Eliminar"
        disabled="@(territorio.TerritoryID == 0)">
    Eliminar
</button>

<button class="btn btn-info me-2"
        @onclick="MostrarBusqueda">
    Buscar
</button>

<a class="btn btn-secondary"
   href="/consulta-territorios">
    Consultar
</a>

@if (!string.IsNullOrEmpty(mensaje))
{
    <div class="alert alert-info mt-3 mb-0">@mensaje</div>
}

</div>

</div>
@if (mostrarBusqueda)
{
    <div class="modal fade show"
         style="display:block;background-color:rgba(0,0,0,0.5);">

        <div class="modal-dialog">

            <div class="modal-content">

                <div class="modal-header bg-primary text-white">

                    <h5 class="modal-title">
                        Buscar Territorio
                    </h5>

                    <button type="button"
                            class="btn-close btn-close-white"
                            @onclick="CerrarBusqueda">
                    </button>

                </div>

                <div class="modal-body">

                    <label>Territorio</label>

                    <select class="form-select"
                            @bind="territorioSeleccionado">

                        <option value="">-- Seleccione un territorio --</option>

                        @foreach (var item in listaTerritorios)
                        {
                            <option value="@item.TerritoryID">
                                @item.TerritoryID - @item.NombreTerritorio
                            </option>
                        }

                    </select>

                </div>

                <div class="modal-footer">

                    <button class="btn btn-secondary"
                            @onclick="CerrarBusqueda">
                        Cancelar
                    </button>

                    <button class="btn btn-primary"
                            @onclick="AceptarBusqueda">
                        Aceptar
                    </button>

                </div>

            </div>

        </div>

    </div>
}
@code
{
    [Parameter]
    public int? id { get; set; }

    private TerritorioDTO territorio = new();

    private List<TerritorioDTO> territorios = new();

    private List<TerritorioListaDTO> listaTerritorios = new();

    private int? territorioSeleccionado;

    private bool mostrarBusqueda = false;

    private string mensaje = "";

    protected override async Task OnParametersSetAsync()
    {
        territorios = await TerritorioService.ConsultarTerritorios();

        listaTerritorios = await TerritorioService.ConsultarListaTerritorios();

        if (id.HasValue)
        {
            var resultado = await TerritorioService.BuscarTerritorio(id.Value);

            if (resultado != null)
            {
                territorio = resultado;
            }
        }
        else
        {
            territorio = new TerritorioDTO();
        }
    }

    private void NuevoTerritorio()
    {
        territorio = new TerritorioDTO();
        mensaje = "";
    }

    private async Task Guardar()
    {
        if (string.IsNullOrWhiteSpace(territorio.NombreTerritorio) ||
            string.IsNullOrWhiteSpace(territorio.CountryRegionCode) ||
            string.IsNullOrWhiteSpace(territorio.Grupo))
        {
            mensaje = "Nombre, código de país y grupo son obligatorios.";
            return;
        }

        if (territorio.TerritoryID == 0)
        {
            var nuevoId = await TerritorioService.GuardarTerritorio(territorio);
            mensaje = $"Territorio creado con código {nuevoId}.";
            territorio = await TerritorioService.BuscarTerritorio(nuevoId) ?? new TerritorioDTO();
        }
        else
        {
            await TerritorioService.ActualizarTerritorio(territorio);
            mensaje = "Territorio actualizado correctamente.";
        }

        territorios = await TerritorioService.ConsultarTerritorios();
        listaTerritorios = await TerritorioService.ConsultarListaTerritorios();
    }

    private async Task Eliminar()
    {
        if (territorio.TerritoryID == 0)
            return;

        var exito = await TerritorioService.EliminarTerritorio(territorio.TerritoryID);

        mensaje = exito
            ? "Territorio eliminado correctamente."
            : "No se pudo eliminar: el territorio tiene vendedores o ventas asociadas.";

        if (exito)
        {
            territorio = new TerritorioDTO();
            territorios = await TerritorioService.ConsultarTerritorios();
            listaTerritorios = await TerritorioService.ConsultarListaTerritorios();
        }
    }

    private void MostrarBusqueda()
    {
        mostrarBusqueda = true;
    }

    private async Task AceptarBusqueda()
    {
        if (!territorioSeleccionado.HasValue)
            return;

        var resultado = await TerritorioService.BuscarTerritorio(territorioSeleccionado.Value);

        if (resultado != null)
        {
            territorio = resultado;
        }

        mostrarBusqueda = false;
    }

    private void CerrarBusqueda()
    {
        mostrarBusqueda = false;
    }
}