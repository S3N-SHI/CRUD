@page "/"

<PageTitle>Inicio</PageTitle>

<div class="container-fluid mt-4">

    <div class="card shadow-lg border-0">

        <div class="row g-0">

            <div class="col-md-7 p-5">

                <h1 class="display-4 fw-bold text-primary">
                    Sistema de Gestión de Ventas
                </h1>

                <h3 class="text-secondary">
                    AdventureWorks 2025
                </h3>

                <hr />

                <p class="lead">

                    Bienvenido al sistema de administración de ventas
                    desarrollado para la gestión de clientes, vendedores,
                    productos, categorías, subcategorías, territorios
                    y movimientos de ventas.

                </p>

                <div class="alert alert-primary mt-4">

                    <strong>Módulos disponibles</strong>

                    <ul class="mt-3">

                        <li>👥 Clientes</li>
                        <li>👨‍💼 Vendedores</li>
                        <li>📦 Productos</li>
                        <li>🏷 Categorías</li>
                        <li>🗂 Subcategorías</li>
                        <li>🌎 Territorios</li>
                        <li>🛒 Movimiento de Ventas</li>
                        <li>📊 Reportes</li>

                    </ul>

                </div>

            </div>

            <div class="col-md-5">

                <img src="imagen.png"
                     class="img-fluid rounded-end shadow"
                     style="height:100%;object-fit:cover;" />

            </div>

        </div>

    </div>

    <div class="row mt-4">

        <div class="col-md-3">

            <div class="card shadow text-center">

                <div class="card-body">

                    <h1>👥</h1>

                    <h5>Clientes</h5>

                </div>

            </div>

        </div>

        <div class="col-md-3">

            <div class="card shadow text-center">

                <div class="card-body">

                    <h1>📦</h1>

                    <h5>Productos</h5>

                </div>

            </div>

        </div>

        <div class="col-md-3">

            <div class="card shadow text-center">

                <div class="card-body">

                    <h1>🛒</h1>

                    <h5>Ventas</h5>

                </div>

            </div>

        </div>

        <div class="col-md-3">

            <div class="card shadow text-center">

                <div class="card-body">

                    <h1>📊</h1>

                    <h5>Reportes</h5>

                </div>

            </div>

        </div>

    </div>

    <div class="card mt-4 shadow">

        <div class="card-body">

            <h4 class="text-primary">
                Información del Proyecto
            </h4>

            <hr />

            <p><strong>Universidad:</strong> ULEAM</p>

            <p><strong>Carrera:</strong> Tecnologías de la Información</p>

            <p><strong>Asignatura:</strong> Desarrollo para SGBD</p>

            <p><strong>Base de Datos:</strong> AdventureWorks2025</p>

            <p><strong>Tecnología:</strong> ASP.NET Core Blazor + SQL Server</p>

        </div>

    </div>

</div>