@page "/password"
@rendermode InteractiveServer

@inject AdventureWorksVentas.Services.UsuarioService UsuarioService

<PageTitle>Reinicio de Contraseña</PageTitle>

<h3>Reinicio de Contraseña</h3>

<div class="card shadow mt-3" style="max-width:500px">

    <div class="card-header bg-primary text-white">
        Restablecer contraseña de un usuario
    </div>

    <div class="card-body">

        <div class="mb-3">
            <label class="form-label fw-bold">Nombre de Usuario</label>
            <input class="form-control" @bind="nombreUsuario" placeholder="ej: admin" />
        </div>

        <div class="mb-3">
            <label class="form-label fw-bold">Nueva Contraseña</label>
            <input type="password" class="form-control" @bind="passwordNueva" />
        </div>

        <div class="mb-3">
            <label class="form-label fw-bold">Confirmar Contraseña</label>
            <input type="password" class="form-control" @bind="passwordConfirmar" />
        </div>

        <button class="btn btn-primary" @onclick="Restablecer">Restablecer Contraseña</button>

        @if (!string.IsNullOrEmpty(mensaje))
        {
            <div class="alert @(exito ? "alert-success" : "alert-warning") mt-3 mb-0">@mensaje</div>
        }

    </div>

</div>

@code {
    private string nombreUsuario = "";
    private string passwordNueva = "";
    private string passwordConfirmar = "";
    private string mensaje = "";
    private bool exito = false;

    private async Task Restablecer()
    {
        if (string.IsNullOrWhiteSpace(nombreUsuario))
        {
            mensaje = "Ingresá el nombre de usuario.";
            exito = false;
            return;
        }

        if (string.IsNullOrWhiteSpace(passwordNueva) || passwordNueva.Length < 6)
        {
            mensaje = "La contraseña debe tener al menos 6 caracteres.";
            exito = false;
            return;
        }

        if (passwordNueva != passwordConfirmar)
        {
            mensaje = "Las contraseñas no coinciden.";
            exito = false;
            return;
        }

        var resultado = await UsuarioService.ResetPassword(nombreUsuario, passwordNueva);

        exito = resultado;

        mensaje = resultado
            ? "Contraseña actualizada correctamente."
            : "No existe ningún usuario con ese nombre de usuario.";

        if (resultado)
        {
            passwordNueva = "";
            passwordConfirmar = "";
        }
    }
}
